generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PI
  CO_PI
  JRF
  ADMIN
}

enum GrantType {
  ARG
  IRG
  PM_ECRG
}

enum ProjectStatus {
  ACTIVE
  EXTENDED
  CLOSED
  PENDING
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

enum DocumentType {
  PROPOSAL
  PROGRESS_REPORT
  EXPENDITURE_STATEMENT
  UTILIZATION_CERTIFICATE
  COMPLETION_REPORT
  OTHER
}

enum BudgetCategory {
  RECURRING
  NON_RECURRING
}

enum MessageType {
  CHAT
  DAILY_REPORT
  FEEDBACK
}

enum ProcurementStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  RECEIVED
  PAID
}

enum SourcingType {
  GEM
  NON_GEM
  PROPRIETARY
}

// ============================================================
// BANK STATEMENT MODULE — new enums
// ============================================================

enum BankName {
  CANARA
  SBI
}

enum ParsingStatus {
  PENDING
  PARSED
  FAILED
  NEEDS_REVIEW
}

enum TransactionCategory {
  INTEREST
  GRANT
  BANK_CHARGE
  TAX
  REFUND
  EXPENDITURE
  UNCATEGORIZED
}

enum AllocationMethod {
  PRO_RATA_BALANCE
  MANUAL
}

enum MatchConfidence {
  EXACT
  LIKELY
  UNCERTAIN
  UNMATCHED
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(PI)
  employeeId  String?  @unique
  institution String?
  designation String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectsAsPi         Project[]            @relation("ProjectPI")
  personnelRecords     PersonnelRecord[]
  uploadedDocuments    Document[]
  createdMilestones    Milestone[]
  notifications        Notification[]
  messages             Message[]            @relation("UserMessages")
  anrfTemplates        AnrfTemplate[]
  procurementRequests  ProcurementRequest[] @relation("ProcurementSubmitter")
  approvedRequests     ProcurementRequest[] @relation("ProcurementApprover")
  grantReleasesLogged GrantRelease[]

  bankStatementsUploaded BankStatement[]
  auditLogsPerformed     AuditLog[]

  @@map("users")
}

model Project {
  id              String        @id @default(cuid())
  title           String
  shortTitle      String?
  grantType       GrantType
  sanctionNumber  String        @unique
  startDate       DateTime
  endDate         DateTime
  status          ProjectStatus @default(ACTIVE)
  hostInstitution String
  abstractText    String?
  totalBudget     Decimal       @db.Decimal(15, 2)
  piId            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  pi                  User                 @relation("ProjectPI", fields: [piId], references: [id])
  milestones          Milestone[]
  documents           Document[]
  budgetHeads         BudgetHead[]
  personnelRecords    PersonnelRecord[]
  expenditures        Expenditure[]
  threads             Thread[]
  assets              Asset[]
  procurementRequests ProcurementRequest[]
  grantReleases GrantRelease[]

  bankStatements   BankStatement[]
  bankTransactions BankTransaction[]
  auditLogs        AuditLog[]

  @@index([piId])
  @@index([status])
  @@index([grantType])
  @@map("projects")
}

model BudgetHead {
  id              String         @id @default(cuid())
  projectId       String
  category        BudgetCategory
  headName        String
  allocatedAmount Decimal        @db.Decimal(15, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenditures        Expenditure[]
  procurementRequests ProcurementRequest[]

  @@index([projectId])
  @@map("budget_heads")
}

model Expenditure {
  id              String   @id @default(cuid())
  projectId       String
  budgetHeadId    String
  amount          Decimal  @db.Decimal(15, 2)
  description     String
  voucherNumber   String?
  expenditureDate DateTime
  createdAt       DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetHead BudgetHead @relation(fields: [budgetHeadId], references: [id], onDelete: Cascade)

  paymentReleaseRequest PaymentReleaseRequest?

  matchedBankTransactions BankTransaction[]

  @@index([projectId])
  @@map("expenditures")
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime
  completedAt DateTime?
  status      MilestoneStatus @default(PENDING)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@map("milestones")
}

model Document {
  id                   String       @id @default(cuid())
  projectId            String
  uploadedById         String
  title                String
  documentType         DocumentType
  fileUrl              String
  fileSize             Int?
  mimeType             String?
  expiryDate           DateTime?
  createdAt            DateTime     @default(now())
  procurementRequestId String?
  checklistKey         String?      // which checklist item (e.g. "REQUISITION_FORM") this upload satisfies

  procurementRequest ProcurementRequest? @relation(fields: [procurementRequestId], references: [id])
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy          User                @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@map("documents")
}

model PersonnelRecord {
  id        String    @id @default(cuid())
  projectId String
  userId    String
  role      Role
  joinDate  DateTime
  endDate   DateTime?
  stipend   Decimal?  @db.Decimal(10, 2)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("personnel_records")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model Thread {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id          String              @id @default(cuid())
  threadId    String
  thread      Thread              @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User                @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  messageType MessageType         @default(CHAT)
  parentId    String?
  parent      Message?            @relation("MessageReplies", fields: [parentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  replies     Message[]           @relation("MessageReplies")
  isRead      Boolean             @default(false)
  createdAt   DateTime            @default(now())
  attachments MessageAttachment[]
}

model AnrfTemplate {
  id           Int      @id @default(autoincrement())
  name         String
  originalName String
  category     String   @default("Other")
  fileType     String   @default("other")
  fileSize     String
  filePath     String
  createdAt    DateTime @default(now())

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  @@map("anrf_templates")
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  @@index([messageId])
  @@map("message_attachments")
}

model Asset {
  id                   String   @id @default(cuid())
  projectId            String
  procurementRequestId String?
  name                 String
  category             String?
  purchaseAmount       Decimal  @db.Decimal(15, 2)
  acquisitionDate      DateTime
  createdAt            DateTime @default(now())

  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  procurementRequest ProcurementRequest? @relation(fields: [procurementRequestId], references: [id])

  @@index([projectId])
  @@map("assets")
}

// ============================================================
// PROCUREMENT MODULE — Simplified ANRF Workflow
// ============================================================

model ProcurementRequest {
  id           String @id @default(cuid())
  projectId    String
  budgetHeadId String

  submittedById String

  itemName        String
  itemDescription String
  quantity        Int
  estimatedCost   Decimal @db.Decimal(15, 2)
  justification   String

  sourcingType   SourcingType @default(NON_GEM)
  vendorName     String?
  vendorAddress  String?
  vendorGst      String?
  quoteReference String?

  status          ProcurementStatus @default(DRAFT)
  rejectionReason String?

  approvedById String?
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetHead  BudgetHead @relation(fields: [budgetHeadId], references: [id], onDelete: Cascade)
  submittedBy User       @relation("ProcurementSubmitter", fields: [submittedById], references: [id])
  approvedBy  User?      @relation("ProcurementApprover", fields: [approvedById], references: [id])

  documents Document[]
  assets    Asset[]

  goodsReceipt          GoodsReceipt?
  paymentReleaseRequest PaymentReleaseRequest?

  @@index([projectId])
  @@index([status])
  @@map("procurement_requests")
}

model GoodsReceipt {
  id                     String    @id @default(cuid())
  procurementRequestId   String    @unique
  deliveryDate           DateTime
  installationDate       DateTime?
  condition              String
  installationReportNote String?
  createdAt              DateTime  @default(now())

  procurementRequest ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)

  @@map("goods_receipts")
}

model PaymentReleaseRequest {
  id                   String    @id @default(cuid())
  procurementRequestId String    @unique
  invoiceNumber        String
  invoiceAmount        Decimal   @db.Decimal(15, 2)
  invoiceDate          DateTime
  checklistComplete    Boolean   @default(false)
  releasedAt           DateTime?
  expenditureId        String?   @unique
  createdAt            DateTime  @default(now())

  procurementRequest ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)
  expenditure         Expenditure?       @relation(fields: [expenditureId], references: [id])

  @@map("payment_release_requests")
}

model GrantRelease {
  id            String   @id @default(cuid())
  projectId     String
  sanctionNo    String
  sanctionDate  DateTime
  amount        Decimal  @db.Decimal(15, 2)
  financialYear String   // e.g. "2025-2026"
  remarks       String?
  createdById   String
  createdAt     DateTime @default(now())

  // Phase 1 additions — nullable, backward compatible with existing rows/routes
  recurringAmount    Decimal? @db.Decimal(15, 2)
  nonRecurringAmount Decimal? @db.Decimal(15, 2)
  utr                String?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@index([financialYear])
  @@map("grant_releases")
}

// ============================================================
// BANK STATEMENT MODULE — new models (Phase 1)
// ============================================================

model BankStatement {
  id                    String        @id @default(cuid())
  projectId             String
  bankName              BankName
  accountNumber         String
  statementPeriodStart  DateTime
  statementPeriodEnd    DateTime
  uploadedById          String
  originalFileUrl       String
  parsingStatus         ParsingStatus @default(PENDING)
  parsingErrors         String?
  openingBalance        Decimal?      @db.Decimal(15, 2)
  closingBalance        Decimal?      @db.Decimal(15, 2)
  createdAt             DateTime      @default(now())

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy   User              @relation(fields: [uploadedById], references: [id])
  transactions BankTransaction[]

  @@index([projectId])
  @@map("bank_statements")
}

model BankTransaction {
  id                   String              @id @default(cuid())
  statementId          String
  projectId            String
  transactionDate      DateTime
  narration            String
  referenceNumber      String?
  debit                Decimal?            @db.Decimal(15, 2)
  credit               Decimal?            @db.Decimal(15, 2)
  balance              Decimal             @db.Decimal(15, 2)
  category             TransactionCategory @default(UNCATEGORIZED)
  matchedExpenditureId String?
  matchConfidence      MatchConfidence?
  recurringShare       Decimal?            @db.Decimal(15, 2)
  nonRecurringShare    Decimal?            @db.Decimal(15, 2)
  createdAt            DateTime            @default(now())

  statement          BankStatement        @relation(fields: [statementId], references: [id], onDelete: Cascade)
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  matchedExpenditure Expenditure?         @relation(fields: [matchedExpenditureId], references: [id])
  interestAllocation InterestAllocation?

  @@index([statementId])
  @@index([projectId])
  @@index([category])
  @@map("bank_transactions")
}

model InterestAllocation {
  id                         String           @id @default(cuid())
  bankTransactionId          String           @unique
  recurringInterest          Decimal          @db.Decimal(15, 2)
  nonRecurringInterest       Decimal          @db.Decimal(15, 2)
  recurringBalanceBefore     Decimal          @db.Decimal(15, 2)
  nonRecurringBalanceBefore  Decimal          @db.Decimal(15, 2)
  allocationMethod           AllocationMethod @default(PRO_RATA_BALANCE)
  calculatedAt               DateTime         @default(now())

  bankTransaction BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)

  @@map("interest_allocations")
}

model CategorizationRule {
  id        String              @id @default(cuid())
  keyword   String              @unique
  category  TransactionCategory
  priority  Int                 @default(0)
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())

  @@index([isActive])
  @@map("categorization_rules")
}

model AuditLog {
  id            String   @id @default(cuid())
  projectId     String?
  entityType    String   // e.g. "BankTransaction", "InterestAllocation", "GrantRelease"
  entityId      String
  action        String   // e.g. "AUTO_CATEGORIZE", "AUTO_MATCH", "INTEREST_ALLOCATE", "UC_GENERATE"
  formulaUsed   String?
  performedById String?
  createdAt     DateTime @default(now())

  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  performedBy User?    @relation(fields: [performedById], references: [id])

  @@index([projectId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
